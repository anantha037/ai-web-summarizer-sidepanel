{
  "manifest_version": 3,
  "name": "Webpage Summarizer & Q&A",
  "version": "1.0",
  "description": "Summarize webpages and ask questions using Gemini API.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "contextMenus",
    "sidePanel"
  ],
  "action": {},
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
